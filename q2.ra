// Find the names of customers who took out a “jumbo mortgage” loan 
// or have a credit rating of at least 750. 
// The output should be a table with a "name" column.

// DONE!
\rename_{name}
\project_{cname} 
    \select_{type='jumbo mortgage'} (borrower \join_{lno = no} loan)
\union
    \project_{name} \select_{credit >= 750} customer;




